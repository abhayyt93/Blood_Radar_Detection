<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#C62828" android:orientation="horizontal"
        android:padding="16dp" android:gravity="center_vertical"
        android:paddingTop="36dp">
        <TextView android:id="@+id/btnBack" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="←"
            android:textColor="#FFFFFF" android:textSize="22sp" android:paddingEnd="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Broadcast Notification"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Title Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📌 Notification Title (Optional)" android:textSize="15sp"
                android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etBroadcastTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext_selector"
                android:hint="Enter title..."
                android:padding="12dp" android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Message Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📢 Broadcast Message" android:textSize="15sp"
                android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etBroadcastMessage"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext_selector"
                android:hint="Enter message to broadcast..."
                android:minLines="3" android:gravity="top"
                android:padding="12dp" android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- Send to All -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥 Send to ALL Users"
                android:textSize="14sp" android:textColor="#555555" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/btnSendToAll"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Send to All Users"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/button_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginBottom="24dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#DDDDDD" android:layout_marginBottom="20dp"/>

            <!-- City Filter -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏙️ Send to Specific City"
                android:textSize="14sp" android:textColor="#555555" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etBroadcastCity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext_selector"
                android:hint="City name (e.g. Mumbai)"
                android:padding="12dp" android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/btnSendToCity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Send to City"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/button_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginBottom="24dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#DDDDDD" android:layout_marginBottom="20dp"/>

            <!-- Blood Group Filter -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🩸 Send by Blood Group"
                android:textSize="14sp" android:textColor="#555555" android:layout_marginBottom="8dp"/>
            <Spinner android:id="@+id/spinnerBloodGroup"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/dropdown_bg"
                android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/btnSendToBloodGroup"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Send to Blood Group"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:background="@drawable/button_bg" android:gravity="center"
                android:padding="12dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
