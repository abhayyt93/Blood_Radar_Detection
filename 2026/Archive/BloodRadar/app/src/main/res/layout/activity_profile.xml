<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorPrimary"
    android:fitsSystemWindows="true">

    <!-- Modern Toolbar with Back Arrow -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:elevation="0dp"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"
        app:titleTextAppearance="@style/ToolbarTitle"
        app:title="My Profile"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <!-- Profile Image Area -->
                <FrameLayout
                    android:id="@+id/layoutProfileImage"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfilePic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/white"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#FFCDD2"
                        app:strokeWidth="2dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvProfileInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/user_circle_bg"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="@color/colorPrimary"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand_bold"
                        android:elevation="4dp"/>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        app:fabSize="mini"
                        app:srcCompat="@android:drawable/ic_menu_camera"
                        app:backgroundTint="@color/white"
                        app:tint="@color/colorPrimary"
                        android:elevation="6dp"
                        android:clickable="false"
                        android:focusable="false"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Profile"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:fontFamily="@font/quicksand_bold"/>
            </LinearLayout>

            <!-- Profile Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                android:layout_marginTop="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Name"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <!-- Phone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_call"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- City -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_map"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="City"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvCity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blood Group -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_blood_type"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Group"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvBloodGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- User Type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="User Type"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvUserType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start"
                        android:layout_marginBottom="0dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:tint="@color/colorPrimary"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bio"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextSecondary"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvBio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="17sp"
                                android:textColor="@color/colorText"
                                android:textStyle="bold"
                                android:fontFamily="@font/quicksand_bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- My Contact Requests (Donor ke liye) -->
            <Button
                android:id="@+id/btnContactRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Contact Requests"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/white"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:fontFamily="@font/quicksand_bold"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
