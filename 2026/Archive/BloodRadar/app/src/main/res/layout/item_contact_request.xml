<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Requester Name -->
        <TextView
            android:id="@+id/tvRequesterName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Requester Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/quicksand_bold"
            android:layout_marginBottom="4dp"/>

        <!-- Requester Blood Group + City -->
        <TextView
            android:id="@+id/tvRequesterInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🩸 A+ • Delhi"
            android:textSize="13sp"
            android:textColor="@color/colorText"
            android:fontFamily="@font/quicksand_regular"
            android:layout_marginBottom="8dp"/>

        <!-- Donation Info -->
        <TextView
            android:id="@+id/tvDonationInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Wants your number for: O+ donation in Noida"
            android:textSize="13sp"
            android:textColor="#555555"
            android:fontFamily="@font/quicksand_regular"
            android:layout_marginBottom="12dp"/>

        <!-- Accept / Reject Buttons -->
        <LinearLayout
            android:id="@+id/layoutButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✅ Accept"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#4CAF50"
                android:textColor="@color/white"
                android:fontFamily="@font/quicksand_bold"/>

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❌ Reject"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/white"
                android:fontFamily="@font/quicksand_bold"/>

        </LinearLayout>

        <!-- Status badge (shown after response) -->
        <TextView
            android:id="@+id/tvResponseStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Accepted"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone"
            android:fontFamily="@font/quicksand_bold"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
